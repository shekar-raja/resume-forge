{
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "/Users/rshekar/Library/TinyTeX/bin/universal-darwin/pdflatex",
      "args": ["-synctex=1", "-interaction=nonstopmode", "-file-line-error", "%DOC%"],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex x2",
      "tools": ["pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.latex.outDir": "%DIR%",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux", "*.bbl", "*.blg", "*.idx", "*.ind", "*.lof",
    "*.lot", "*.out", "*.toc", "*.acn", "*.acr", "*.alg",
    "*.glg", "*.glo", "*.gls", "*.fls", "*.log", "*.fdb_latexmk",
    "*.snm", "*.synctex(busy)", "*.synctex.gz(busy)", "*.nav"
  ],
  "latex-workshop.latex.autoClean.run": "onBuilt",
  "[latex]": {
    "editor.wordWrap": "on",
    "editor.formatOnSave": false
  },
  "files.exclude": {
    "**/*.aux": true,
    "**/*.log": true,
    "**/*.out": true,
    "**/*.fls": true,
    "**/*.fdb_latexmk": true,
    "**/*.synctex.gz": true,
    "**/*.synctex(busy)": true
  }
}
